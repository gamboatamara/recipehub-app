# Variables para Docker Compose
# Copiar este archivo a .env y completar los valores reales

# MongoDB — credenciales del contenedor mongo
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
MONGO_INITDB_DATABASE=

# URI completa que usa el contenedor api para conectarse a mongo
# El host debe ser 'mongo' (nombre del servicio en docker-compose)
# Ejemplo: mongodb://USUARIO:PASSWORD@mongo:27017/NOMBRE_DB?authSource=admin
MONGO_URI=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Puerto del servidor API
PORT=4000
