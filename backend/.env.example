# Puerto local donde escucha la API de Express.
PORT=4000

# Cadena de conexion a MongoDB.
# Desarrollo local: mongodb://127.0.0.1:27017/recipehub
# Docker Compose: mongodb://MONGO_USER:MONGO_PASSWORD@mongo:27017/recipehub?authSource=admin
MONGO_URI=mongodb://127.0.0.1:27017/recipehub

# Secreto usado para firmar y validar tokens JWT.
JWT_SECRET=change_me

# Tiempo de expiracion de los tokens JWT.
JWT_EXPIRES_IN=7d

# Nombre del cloud de Cloudinary para almacenar imagenes.
CLOUDINARY_CLOUD_NAME=change_me

# API key de Cloudinary.
CLOUDINARY_API_KEY=change_me

# API secret de Cloudinary.
CLOUDINARY_API_SECRET=change_me
