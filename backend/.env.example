PORT=4000

# Desarrollo local (sin Docker): apunta a localhost
# Produccion con Docker Compose: cambiar 'localhost' por 'mongo' y agregar credenciales
# Ejemplo Docker: mongodb://MONGO_USER:MONGO_PASSWORD@mongo:27017/recipehub?authSource=admin
MONGO_URI=

JWT_SECRET=
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=change_me
CLOUDINARY_API_KEY=change_me
CLOUDINARY_API_SECRET=change_me
